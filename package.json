{
  "name": "pokemath",
  "scripts": {
    "start:dev": "docker compose -f compose.yaml -f compose.dev.yaml up --build --watch",
    "start:prod": "docker compose -f compose.yaml -f compose.prod.yaml up -d",
    "stop:dev": "docker compose -f compose.yaml -f compose.dev.yaml down",
    "start:prod": "docker compose -f compose.yaml -f compose.prod.yaml down"
  }
}
